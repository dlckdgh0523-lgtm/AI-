# Anthropic (Claude API) — 오케스트레이터/서브에이전트/검증기
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — 법령 조문·질의 임베딩 (voyage-3.5, 1024차원)
VOYAGE_API_KEY=pa-...

# Neo4j AuraDB — 법령 지식그래프 + 벡터 인덱스 + 의미 캐시
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...

# 법제처 국가법령정보센터 Open API (https://open.law.go.kr) — OC = 발급받은 이메일 ID
LAW_API_OC=...

# 네이버 개발자센터 (https://developers.naver.com) — 쇼핑/블로그 검색 API
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# Supabase — 대화 로그 저장 + 대시보드
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# 서버 전용 키 (대시보드 로그 조회용, RLS로 anon SELECT를 차단한 경우 필수)
SUPABASE_SERVICE_ROLE_KEY=...
